{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/rf-frame.schema.json",
  "title": "RF sensing frame",
  "type": "object",
  "required": ["schema_version", "timestamp_ms", "source", "privacy", "metrics"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "object",
      "required": ["kind", "hardware"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["simulator", "csi", "bfi", "rssi", "rtt", "fusion"]
        },
        "hardware": {
          "type": "string"
        },
        "channel": {
          "type": "integer"
        },
        "bandwidth_mhz": {
          "type": "integer",
          "enum": [20, 40, 80, 160, 320]
        }
      },
      "additionalProperties": true
    },
    "privacy": {
      "type": "object",
      "required": ["consent_scope", "identity_free"],
      "properties": {
        "consent_scope": {
          "type": "string",
          "enum": ["lab", "single_room", "whole_home", "unknown"]
        },
        "identity_free": {
          "type": "boolean"
        },
        "raw_retention": {
          "type": "string",
          "enum": ["none", "session", "local_archive", "unknown"]
        }
      },
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x", "y"],
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "number", "minimum": 0, "maximum": 1 },
          "y": { "type": "number", "minimum": 0, "maximum": 1 },
          "rssi_dbm": { "type": "number" },
          "antenna": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x", "y", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "number", "minimum": 0, "maximum": 1 },
          "y": { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "motion": { "type": "number", "minimum": 0, "maximum": 1 },
          "label": {
            "type": "string",
            "enum": ["anonymous_presence", "motion_zone", "unknown"]
          }
        },
        "additionalProperties": true
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x", "y"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "x": { "type": "number", "minimum": 0, "maximum": 1 },
          "y": { "type": "number", "minimum": 0, "maximum": 1 },
          "z": { "type": "number", "minimum": 0 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source": {
            "type": "string",
            "enum": ["manual", "phone-marker", "external", "simulator", "unknown"]
          }
        },
        "additionalProperties": true
      }
    },
    "heatmap": {
      "type": "object",
      "required": ["cols", "rows", "values"],
      "properties": {
        "cols": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "values": {
          "type": "array",
          "items": { "type": "number", "minimum": 0 }
        }
      },
      "additionalProperties": false
    },
    "ranges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["nodeId", "range_m"],
        "properties": {
          "nodeId": { "type": "string" },
          "range_m": { "type": "number", "minimum": 0 },
          "variance": { "type": "number", "minimum": 0 },
          "rssi_dbm": { "type": "number" },
          "source": {
            "type": "string",
            "enum": ["rtt", "rssi_model", "csi_model", "manual", "simulator"]
          }
        },
        "additionalProperties": true
      }
    },
    "phone_pose": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" },
        "heading_deg": { "type": "number" },
        "sigma": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "imu": {
      "type": "object",
      "properties": {
        "ax": { "type": "number" },
        "ay": { "type": "number" },
        "az": { "type": "number" },
        "room_ax": { "type": "number" },
        "room_ay": { "type": "number" },
        "magnitude": { "type": "number", "minimum": 0 },
        "yaw_deg": { "type": "number" },
        "beta_deg": { "type": "number" },
        "gamma_deg": { "type": "number" },
        "phone_motion": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "required": ["occupancy", "confidence", "motion", "noise"],
      "properties": {
        "occupancy": { "type": "integer", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "motion": { "type": "number", "minimum": 0, "maximum": 1 },
        "noise": { "type": "number", "minimum": 0, "maximum": 1 },
        "latency_ms": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "message"],
        "properties": {
          "level": { "type": "string", "enum": ["info", "warn", "error"] },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
